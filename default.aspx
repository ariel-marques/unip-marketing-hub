  <button id="backToTop" class="btn btn-dark" aria-label="Voltar ao topo"> Voltar ao topo </button>

  <script>
    window.addEventListener("scroll", function () {
      const header = document.getElementById("topo");
      const nav = header.querySelector("nav");
      const logo = document.getElementById("logo-unip");

      if (window.scrollY > 30) {
        header.classList.add("scrolled");
        nav.classList.remove("bg-azul-naval");
        logo.src = "/assets/img/logo/logo-unip-azul.svg";
      } else {
        header.classList.remove("scrolled");
        nav.classList.add("bg-azul-naval");
        logo.src = "/assets/img/logo/logo-unip.svg";
      }
    });


    // Script to load latest comunicados on home page
    document.addEventListener("DOMContentLoaded", async () => {
      const container = document.getElementById("comunicados-home");
      if (!container) return;

      // caminho da p&aacute;gina de comunicados
      const COMUNICADOS_URL = "/marketing/comunicados.aspx";

      // helper pra converter datas
      function parseDate(str) {
        if (!str) return null;

        // 1) tenta ISO (2026-01-03)
        if (/^\d{4}-\d{2}-\d{2}$/.test(str)) {
          return new Date(str + "T00:00:00");
        }

        // 2) tenta dd/mm/yyyy
        if (/^\d{2}\/\d{2}\/\d{4}$/.test(str)) {
          const [d, m, y] = str.split("/");
          return new Date(+y, +m - 1, +d);
        }

        // fallback
        const d = new Date(str);
        return isNaN(d.getTime()) ? null : d;
      }

      try {
        const resp = await fetch(COMUNICADOS_URL, { credentials: "include" });
        const html = await resp.text();

        const parser = new DOMParser();
        const doc = parser.parseFromString(html, "text/html");

        const artigos = Array.from(doc.querySelectorAll("#lista-comunicados .comunicado"));

        if (!artigos.length) {
          container.innerHTML = "<p class='text-muted'>Nenhum comunicado encontrado.</p>";
          return;
        }

        const today = new Date();

        // transforma em array rico
        const items = artigos.map((art) => {
          const titulo = art.querySelector("h3")?.textContent.trim() || "Comunicado";
          const timeEl = art.querySelector("time");
          const dateAttr = timeEl?.getAttribute("datetime")?.trim();
          const dateText = timeEl?.textContent.trim();
          const dateObj = parseDate(dateAttr || dateText);
          const texto = art.querySelector("p")?.textContent.trim() || "";
          const resumo = texto.length > 140 ? texto.slice(0, 140) + "..." : texto;
          const id = art.getAttribute("id");

          // decide se &eacute; novo (<= 7 dias)
          let isNew = false;
          if (dateObj && !isNaN(dateObj)) {
            const diffDays = (today - dateObj) / (1000 * 60 * 60 * 24);
            if (diffDays <= 7) {
              isNew = true;
            }
          }

          return {
            titulo,
            resumo,
            dateText: dateText || "",
            dateObj: dateObj || new Date(0),
            id,
            isNew
          };
        });

        // ordena do mais novo pro mais antigo
        items.sort((a, b) => b.dateObj - a.dateObj);

        // pega s&oacute; os 3 primeiros
        const top3 = items.slice(0, 3);

        container.innerHTML = top3
          .map((item) => {
            const link = item.id ? `${COMUNICADOS_URL}#${item.id}` : COMUNICADOS_URL;

            return `
          <div class="col-12 col-md-6 col-lg-4 mb-5">
            <div class="card card-comunicados bg-light shadow-sm h-100 rounded-5 position-relative">
              ${item.isNew ? `<span class="badge-novo-card">Novo</span>` : ""}
              <div class="card-body m-4">
                <h5 class="card-title fw-bold">${item.titulo}</h5>
                <p class="card-text">${item.resumo}</p>
                <a href="${link}" class="text-primary text-decoration-none fw-semibold">Ler mais</a>
              </div>
              <div class="card-footer bg-transparent border-0 text-center">
                <span class="badge badge-comunicados rounded-pill px-3 py-2">
                  ${item.dateText ? "Publicado em " + item.dateText : ""}
                </span>
              </div>
            </div>
          </div>
        `;
          })
          .join("");
      } catch (err) {
        console.error("Erro ao carregar comunicados:", err);
        container.innerHTML = "<p class='text-muted'>N&atilde;o foi poss&iacute;vel carregar os comunicados.</p>";
      }
    });
  </script>
